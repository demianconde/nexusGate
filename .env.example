# NexusGate — configuração de ambiente (copie para .env e ajuste)

# App
NEXUS_ENV=development                # development | production
NEXUS_PORT=8000
NEXUS_LOG_LEVEL=INFO
NEXUS_LOG_JSON=false                  # true em produção

# Banco de dados (Postgres async)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/nexusgate

# Redis (cache semântico + rate limiting)
REDIS_URL=redis://localhost:6379/0

# Supabase (auth do painel) — preenchido na Fase 1
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Envelope encryption (BYOK) — preenchido na Fase 2
# Chave mestra (KEK) base64. Gere com:  python -c "import base64,os;print(base64.b64encode(os.urandom(32)).decode())"
NEXUS_MASTER_KEY=

# Stripe (billing) — preenchido na Fase 5
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
