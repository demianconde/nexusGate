# AegisFlow — configuração de ambiente (copie para .env e ajuste)

# App
AEGIS_ENV=development                # development | production
AEGIS_PORT=8000
AEGIS_LOG_LEVEL=INFO
AEGIS_LOG_JSON=false                  # true em produção

# Banco de dados (Postgres async)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/aegisflow

# Redis (cache semântico + rate limiting)
REDIS_URL=redis://localhost:6379/0

# Supabase (auth do painel) — preenchido na Fase 1
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Console do dono (/gestaoaegis): e-mails autorizados (Gmail), separados por vírgula
AEGIS_OWNER_EMAILS=

# Envelope encryption (BYOK) — preenchido na Fase 2
# Chave mestra (KEK) base64. Gere com:  python -c "import base64,os;print(base64.b64encode(os.urandom(32)).decode())"
AEGIS_MASTER_KEY=

# Segurança
AEGIS_PII_GUARD=false                 # true: redige PII antes de provedores hospedados (LGPD)
AEGIS_ALLOW_PRIVATE_ENDPOINTS=false   # true só em self-host (permite Ollama/local em rede privada)
AEGIS_RATELIMIT_FAIL_CLOSED=false     # true: bloqueia (503) se o Redis cair
AEGIS_CORS_ORIGINS=                   # produção: https://app.seudominio.com.br,https://...
AEGIS_METRICS_TOKEN=                  # se definido, /metrics exige Authorization: Bearer <token>

# Anti-abuso do cadastro grátis (Sybil / multi-conta)
AEGIS_BLOCK_DISPOSABLE_EMAIL=true     # bloqueia e-mail temporário/descartável no cadastro
AEGIS_DISPOSABLE_EMAIL_DOMAINS=       # domínios descartáveis extras (vírgula), além da lista built-in
AEGIS_SIGNUP_IP_DAILY_LIMIT=5         # máx. de contas novas por IP/dia (0 = sem limite)

# Cache semântico (embeddings locais via Ollama)
AEGIS_CACHE_ENABLED=true
AEGIS_CACHE_THRESHOLD=0.92
AEGIS_CACHE_MAX_ENTRIES=1000          # teto de entradas por tenant (anti-DoS de memória)
AEGIS_EMBED_URL=http://localhost:11434
AEGIS_EMBED_MODEL=            # ex.: nomic-embed-text ou um modelo do Ollama; vazio desliga o cache

# Stripe (billing) — homologação usa chaves de TESTE (sk_test_/whsec_). Ver STRIPE.md
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
AEGIS_STRIPE_PAYMENT_METHODS=card     # cartão (recorrente); Pix é one-time, não p/ assinatura
