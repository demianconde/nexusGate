# NexusGate — configuração de ambiente (copie para .env e ajuste)

# App
NEXUS_ENV=development                # development | production
NEXUS_PORT=8000
NEXUS_LOG_LEVEL=INFO
NEXUS_LOG_JSON=false                  # true em produção

# Banco de dados (Postgres async)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/nexusgate

# Redis (cache semântico + rate limiting)
REDIS_URL=redis://localhost:6379/0

# Supabase (auth do painel) — preenchido na Fase 1
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Envelope encryption (BYOK) — preenchido na Fase 2
# Chave mestra (KEK) base64. Gere com:  python -c "import base64,os;print(base64.b64encode(os.urandom(32)).decode())"
NEXUS_MASTER_KEY=

# Segurança
NEXUS_PII_GUARD=false                 # true: redige PII antes de provedores hospedados (LGPD)
NEXUS_ALLOW_PRIVATE_ENDPOINTS=false   # true só em self-host (permite Ollama/local em rede privada)
NEXUS_RATELIMIT_FAIL_CLOSED=false     # true: bloqueia (503) se o Redis cair
NEXUS_CORS_ORIGINS=                   # produção: https://app.seudominio.com.br,https://...
NEXUS_METRICS_TOKEN=                  # se definido, /metrics exige Authorization: Bearer <token>

# Cache semântico (embeddings locais via Ollama)
NEXUS_CACHE_ENABLED=true
NEXUS_CACHE_THRESHOLD=0.92
NEXUS_CACHE_MAX_ENTRIES=1000          # teto de entradas por tenant (anti-DoS de memória)
NEXUS_EMBED_URL=http://localhost:11434
NEXUS_EMBED_MODEL=            # ex.: nomic-embed-text ou um modelo do Ollama; vazio desliga o cache

# Stripe (billing) — preenchido na Fase 5
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
